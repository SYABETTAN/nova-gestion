# Staging — variables sur l'hébergeur (Vercel Environment: Preview / branche staging)
# Base dédiée : esther_staging (jamais partagée avec la production)

APP_ENV=staging
NEXT_PUBLIC_APP_ENV=staging
NODE_ENV=production

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/esther_staging?schema=public&sslmode=require"

SESSION_SECRET="change-me-staging-min-32-characters-unique"

NEXT_PUBLIC_APP_NAME="Nova Gestion (Staging)"
NEXT_PUBLIC_APP_URL="https://staging.votre-domaine.fr"

SEED_DEV_DATA=false
ENABLE_DEV_LOGIN=false
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false

REGISTRATION_MODE=invite_only
ALLOW_PUBLIC_SIGNUP=false
REQUIRE_EMAIL_VERIFICATION=false

EMAIL_PROVIDER=resend
EMAIL_FROM="Nova Gestion <no-reply@staging.votre-domaine.fr>"
EMAIL_REPLY_TO=
RESEND_API_KEY=

STORAGE_PROVIDER=s3
S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
S3_REGION=auto
S3_BUCKET=nova-gestion-staging
S3_ACCESS_KEY=
S3_SECRET_KEY=

LOG_LEVEL=info
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
