# Production — secrets uniquement sur l'hébergeur (jamais commités)

APP_ENV=production
NEXT_PUBLIC_APP_ENV=production
NODE_ENV=production

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/esther?schema=public&sslmode=require"

SESSION_SECRET="change-me-production-min-32-characters-strong-unique"

NEXT_PUBLIC_APP_NAME="Nova Gestion"
NEXT_PUBLIC_APP_URL="https://app.votre-domaine.fr"

SEED_DEV_DATA=false
ENABLE_DEV_LOGIN=false
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false

REGISTRATION_MODE=invite_only
ALLOW_PUBLIC_SIGNUP=false
REQUIRE_EMAIL_VERIFICATION=false

EMAIL_PROVIDER=resend
EMAIL_FROM="Nova Gestion <no-reply@votre-domaine.fr>"
EMAIL_REPLY_TO="support@votre-domaine.fr"
RESEND_API_KEY=

STORAGE_PROVIDER=s3
S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
S3_REGION=auto
S3_BUCKET=nova-gestion-production
S3_ACCESS_KEY=
S3_SECRET_KEY=

LOG_LEVEL=info
SENTRY_DSN=
