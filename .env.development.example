# Développement local — copier vers .env
# PostgreSQL : npm run docker:up puis DATABASE_URL ci-dessous

# --- Environnement ---
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development
NODE_ENV=development

# --- Base de données ---
DATABASE_URL="postgresql://esther:esther@localhost:5432/esther?schema=public"

# --- Auth (min. 32 caractères ; valeur dev uniquement) ---
SESSION_SECRET="development-only-secret-min-32-chars!!"

# --- Application ---
NEXT_PUBLIC_APP_NAME="Nova Gestion"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Inscription ---
REGISTRATION_MODE=open_dev
ALLOW_PUBLIC_SIGNUP=false
REQUIRE_EMAIL_VERIFICATION=false

# --- Développement uniquement (interdit en staging/production) ---
SEED_DEV_DATA=true
ENABLE_DEV_LOGIN=true
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true

# --- Email ---
EMAIL_PROVIDER=log
EMAIL_FROM="Nova Gestion <no-reply@localhost.dev>"
EMAIL_REPLY_TO=
RESEND_API_KEY=

# --- Stockage ---
STORAGE_PROVIDER=local
STORAGE_PATH=./uploads

# --- Observabilité (optionnel) ---
# LOG_LEVEL=debug
# SENTRY_DSN=
