# Modèle principal — voir aussi :
#   .env.development.example  (local)
#   .env.staging.example      (préproduction)
#   .env.production.example   (clients)
#   .env.vercel.example       (déploiement Vercel + Neon)
# Documentation : docs/ENVIRONMENT.md — déploiement : docs/DEPLOY-VERCEL.md

# --- Environnement ---
APP_ENV=development
NEXT_PUBLIC_APP_ENV=development
NODE_ENV=development

# --- Base de données ---
DATABASE_URL="postgresql://esther:esther@localhost:5432/esther?schema=public"

# --- Auth ---
SESSION_SECRET="development-only-secret-min-32-chars!!"

# --- Application ---
NEXT_PUBLIC_APP_NAME="Nova Gestion"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Inscription ---
REGISTRATION_MODE=open_dev
ALLOW_PUBLIC_SIGNUP=false
REQUIRE_EMAIL_VERIFICATION=false

# --- Dev fixtures (false en staging/prod) ---
SEED_DEV_DATA=true
ENABLE_DEV_LOGIN=true
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true

# --- Email ---
EMAIL_PROVIDER=log
EMAIL_FROM="Nova Gestion <no-reply@localhost.dev>"
EMAIL_REPLY_TO=
RESEND_API_KEY=

# --- Stockage ---
STORAGE_PROVIDER=local
STORAGE_PATH=./uploads

# --- Observabilité ---
# LOG_LEVEL=info
# SENTRY_DSN=
