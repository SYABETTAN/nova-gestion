# Variables à copier dans Vercel → Settings → Environment Variables
# Base gratuite recommandée : Neon (https://neon.tech) — PostgreSQL

# --- Obligatoire ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
SESSION_SECRET="générer-32-caractères-minimum-unique-openssl-rand-hex-32"
APP_ENV=production
NEXT_PUBLIC_APP_ENV=production
NODE_ENV=production

NEXT_PUBLIC_APP_NAME="Joey & Joey"
# Remplacer après le 1er déploiement par votre URL Vercel réelle :
NEXT_PUBLIC_APP_URL="https://votre-projet.vercel.app"

SEED_DEV_DATA=false
ENABLE_DEV_LOGIN=false
NEXT_PUBLIC_ENABLE_DEV_LOGIN=false

# --- Inscription démo client (désactiver après onboarding) ---
REGISTRATION_MODE=open_dev
ALLOW_PUBLIC_SIGNUP=true

# --- Email (gratuit : https://resend.com — 100 emails/jour) ---
EMAIL_PROVIDER=resend
EMAIL_FROM="Joey & Joey <onboarding@resend.dev>"
RESEND_API_KEY="re_xxxxxxxx"

# --- Stockage (Vercel : pas de disque persistant — R2 gratuit recommandé) ---
# Option rapide démo sans fichiers persistants :
STORAGE_PROVIDER=local
STORAGE_PATH=/tmp/uploads

# Option durable gratuite (Cloudflare R2) :
# STORAGE_PROVIDER=s3
# S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=nova-gestion
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
