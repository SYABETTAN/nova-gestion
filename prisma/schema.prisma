  id             String             @id @default(cuid())
  organizationId String
  key            String
  value          String
  category       AppSettingCategory @default(OTHER)
  description    String?
  isSystem       Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@index([category])
}

model TaxRate {
  id                          String      @id @default(cuid())
  organizationId              String
  name                        String
  rate                        Decimal @db.Decimal(19, 4)
  type                        TaxRateType @default(VAT)
  country                     String      @default("FR")
  isDefault                   Boolean     @default(false)
  isActive                    Boolean     @default(true)
  description                 String?
  accountingCollectedAccountId String?
  accountingDeductibleAccountId String?
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([isActive])
  @@index([isDefault])
}

model PaymentTerm {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  days           Int
  description    String?
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([isActive])
  @@index([isDefault])
}

model CurrencySetting {
  id                    String   @id @default(cuid())
  organizationId          String
  code                  String
  name                  String
  symbol                String
  exchangeRateToDefault Decimal @db.Decimal(19, 4)    @default(1)
  isDefault             Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([isActive])
}

model LocalizationSetting {
  id             String   @id @default(cuid())
  organizationId String   @unique
  locale         String   @default("fr-FR")
  timezone       String   @default("Europe/Paris")
  dateFormat     String   @default("dd/MM/yyyy")
  numberFormat   String   @default("fr-FR")
  currencyFormat String   @default("fr-FR")
  firstDayOfWeek String   @default("MONDAY")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CommercialPreference {
  id                        String   @id @default(cuid())
  organizationId            String   @unique
  defaultQuoteValidityDays  Int      @default(30)
  defaultQuoteIntroduction  String?
  defaultQuoteFooter        String?
  defaultCustomerPaymentTermId String?
  defaultCustomerTaxRateId  String?
  allowQuoteDiscounts       Boolean  @default(true)
  allowQuoteFreeTextLines   Boolean  @default(true)
  requireCustomerForQuote   Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model InvoicingPreference {
  id                           String   @id @default(cuid())
  organizationId               String   @unique
  defaultInvoicePaymentTermId  String?
  defaultInvoiceTaxRateId      String?
  defaultInvoiceIntroduction   String?
  defaultInvoiceFooter         String?
  defaultCreditNoteFooter      String?
  lockInvoiceAfterValidation   Boolean  @default(true)
  allowInvoiceFromQuote        Boolean  @default(true)
  allowDraftInvoiceDeletionSandbox Boolean @default(false)
  showSandboxLegalNotice       Boolean  @default(false)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model SupplierPreference {
  id                            String   @id @default(cuid())
  organizationId                String   @unique
  defaultSupplierPaymentTermId  String?
  defaultSupplierTaxRateId      String?
  defaultExpenseCategoryId      String?
  requireSupplierInvoiceAttachment Boolean @default(false)
  allowSupplierBankDetailsSandbox Boolean @default(false)
  defaultSupplierRiskLevel      String   @default("LOW")
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AccountingPreference {
  id                                      String   @id @default(cuid())
  organizationId                          String   @unique
  defaultSalesJournalId                 String?
  defaultPurchaseJournalId              String?
  defaultBankJournalId                  String?
  defaultCashJournalId                  String?
  defaultMiscJournalId                  String?
  autoGenerateEntriesFromCustomerInvoices Boolean  @default(false)
  autoGenerateEntriesFromCustomerPayments Boolean  @default(false)
  autoGenerateEntriesFromSupplierInvoices Boolean  @default(false)
  requireBalancedEntriesForValidation   Boolean  @default(true)
  allowDraftUnbalancedEntries           Boolean  @default(true)
  createdAt                             DateTime @default(now())
  updatedAt                             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AccountingMapping {
  id                 String                @id @default(cuid())
  organizationId     String
  type               AccountingMappingType
  label              String
  accountId          String
  taxRateId          String?
  expenseCategoryId  String?
  itemCategoryId     String?
  supplierCategoryId String?
  isDefault          Boolean               @default(false)
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([type])
  @@index([isActive])
}

model NotificationPreference {
  id             String                @id @default(cuid())
  organizationId String
  type           NotificationType
  enabled        Boolean               @default(true)
  channel        NotificationChannel   @default(IN_APP)
  frequency      NotificationFrequency @default(IMMEDIATE)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
  @@index([organizationId])
}

model FeatureFlag {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  name           String
  description    String?
  enabled        Boolean  @default(true)
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
}

model CustomFieldDefinition {
  id             String                @id @default(cuid())
  organizationId String
  entityType     CustomFieldEntityType
  key            String
  label          String
  fieldType      CustomFieldType
  options        String?
  isRequired     Boolean               @default(false)
  isActive       Boolean               @default(true)
  sortOrder      Int                   @default(0)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, entityType, key])
  @@index([organizationId])
  @@index([entityType])
}
