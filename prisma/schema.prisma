enum SearchEntityType {
  CUSTOMER
  ITEM
  QUOTE
  INVOICE
  PAYMENT
  REMINDER
  SUPPLIER
  SUPPLIER_INVOICE
  ACCOUNTING_ENTRY
  DOCUMENT
  EXPORT_JOB
  SETTING
  AUDIT_LOG
  ACTION
}

model SearchHistory {
  id             String            @id @default(cuid())
  organizationId String
  userId         String?
  query          String
  resultType     SearchEntityType?
  resultId       String?
  resultTitle    String?
  clicked        Boolean           @default(false)
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
  @@index([query])
}

model FavoriteEntity {
  id             String           @id @default(cuid())
  organizationId String
  userId         String?
  entityType     SearchEntityType
  entityId       String
  title          String
  subtitle       String?
  href           String
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId, entityType, entityId])
  @@index([organizationId])
  @@index([userId])
  @@index([entityType])
}

model Role {
  id          String     @id @default(cuid())
  key         SystemRole @unique
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  permissions RolePermission[]
  members     OrganizationMember[]
  invitations Invitation[]
}

model Permission {
  id          String        @id @default(cuid())
  key         PermissionKey @unique
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  roles RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  roleId         String
  status         MemberStatus @default(ACTIVE)
  invitedById    String?
  joinedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model Invitation {
  id             String           @id @default(cuid())
  organizationId String
  email          String
  roleId         String
  tokenHash      String           @unique
  status         InvitationStatus @default(PENDING)
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@index([expiresAt])
}

model NumberingSequence {
  id             String                 @id @default(cuid())
  organizationId String
  type           NumberingSequenceType
  prefix         String
  nextNumber     Int                    @default(1)
  padding        Int                    @default(4)
  suffix         String                 @default("")
  resetPeriod    NumberingResetPeriod   @default(NEVER)
  lastResetAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
  @@index([organizationId])
}

model AuditLog {
  id             String      @id @default(cuid())
  organizationId String
  userId         String?
  action         AuditAction
  entityType     String
  entityId       String?
  entityLabel    String?
  oldValues      String?
  newValues      String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

model Customer {
  id                      String         @id @default(cuid())
  organizationId          String
  customerNumber          String
  type                    CustomerType   @default(COMPANY)
  status                  CustomerStatus @default(PROSPECT)
  name                    String
  legalName               String?
  displayName             String?
  email                   String?
