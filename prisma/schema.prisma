  customerNotes      CustomerNote[]
  customerTags       CustomerTag[]
  customerTagAssignments CustomerTagAssignment[]
  customerActivities CustomerActivity[]
  items              Item[]
  itemCategories     ItemCategory[]
  itemUnits          ItemUnit[]
  itemTags           ItemTag[]
  itemTagAssignments ItemTagAssignment[]
  itemPriceHistories ItemPriceHistory[]
  itemActivities     ItemActivity[]
  quotes             Quote[]
  quoteLines         QuoteLine[]
  quoteActivities    QuoteActivity[]
  invoices           Invoice[]
  invoiceLines       InvoiceLine[]
  invoiceActivities  InvoiceActivity[]
  creditNotes        CreditNote[]
  creditNoteLines    CreditNoteLine[]
  payments           Payment[]
  paymentAllocations PaymentAllocation[]
  paymentActivities  PaymentActivity[]
  reminders          Reminder[]
  reminderTemplates  ReminderTemplate[]
  reminderActivities ReminderActivity[]
  reminderNotes      ReminderNote[]
  supplierCategories SupplierCategory[]
  suppliers          Supplier[]
  supplierContacts   SupplierContact[]
  supplierAddresses  SupplierAddress[]
  supplierBankAccounts SupplierBankAccount[]
  supplierNotes      SupplierNote[]
