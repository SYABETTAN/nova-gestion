model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     OrganizationMember[]
  invitationsSent Invitation[]         @relation("InvitedBy")
  auditLogs       AuditLog[]
  customerNotes   CustomerNote[]
  itemPriceChanges ItemPriceHistory[]
  quotesCreated   Quote[]              @relation("QuoteCreatedBy")
  quotesUpdated   Quote[]              @relation("QuoteUpdatedBy")
  quoteActivities QuoteActivity[]
  invoicesCreated Invoice[]            @relation("InvoiceCreatedBy")
  invoicesUpdated Invoice[]            @relation("InvoiceUpdatedBy")
  invoiceActivities InvoiceActivity[]
  creditNotesCreated CreditNote[]      @relation("CreditNoteCreatedBy")
  paymentsReceived Payment[]           @relation("PaymentReceivedBy")
  paymentActivities PaymentActivity[]
  remindersCreated  Reminder[]          @relation("ReminderCreatedBy")
  reminderActivities ReminderActivity[]
  reminderNotes     ReminderNote[]
  supplierNotes     SupplierNote[]
  supplierInvoicesCreated SupplierInvoice[] @relation("SupplierInvoiceCreatedBy")
  supplierInvoicesUpdated SupplierInvoice[] @relation("SupplierInvoiceUpdatedBy")
  supplierInvoiceActivities SupplierInvoiceActivity[]
  supplierInvoiceAttachments SupplierInvoiceAttachment[]
  accountingEntriesCreated AccountingEntry[] @relation("AccountingEntryCreatedBy")
  documentsGenerated     Document[]          @relation("DocumentGeneratedBy")
  exportJobsRequested      ExportJob[]         @relation("ExportJobRequestedBy")
  accountingEntriesValidated AccountingEntry[] @relation("AccountingEntryValidatedBy")
  searchHistory            SearchHistory[]
  favoriteEntities         FavoriteEntity[]
}

